diff --git a/scripts/build/select-bootstrap-debs.py b/scripts/build/select-bootstrap-debs.py
new file mode 100755
index 000000000..e05d0050a
--- /dev/null
+++ b/scripts/build/select-bootstrap-debs.py
@@ -0,0 +1,99 @@
+#!/usr/bin/env python3
+"""Select the compatible transitive .deb closure for a bootstrap archive."""
+
+from __future__ import annotations
+
+import argparse
+import re
+import subprocess
+import sys
+from dataclasses import dataclass
+from email.parser import Parser
+from pathlib import Path
+
+
+@dataclass(frozen=True)
+class Deb:
+    path: Path
+    package: str
+    architecture: str
+    dependencies: str
+    provides: tuple[str, ...]
+
+
+def normalize_name(value: str) -> str:
+    value = re.sub(r"\([^)]*\)|\[[^]]*\]|<[^>]*>", "", value).strip()
+    return value.split(":", 1)[0].strip()
+
+
+def metadata(path: Path) -> Deb:
+    control = subprocess.run(
+        ["dpkg-deb", "--field", str(path)],
+        check=True,
+        capture_output=True,
+        text=True,
+    ).stdout
+    fields = Parser().parsestr(control)
+    dependencies = ", ".join(
+        value for value in (fields.get("Pre-Depends"), fields.get("Depends")) if value
+    )
+    provides = tuple(
+        normalize_name(item)
+        for item in fields.get("Provides", "").split(",")
+        if normalize_name(item)
+    )
+    return Deb(path, fields["Package"], fields["Architecture"], dependencies, provides)
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--debs", type=Path, required=True)
+    parser.add_argument("--arch", required=True)
+    parser.add_argument("packages", nargs="+")
+    args = parser.parse_args()
+
+    records = [metadata(path) for path in sorted(args.debs.glob("*.deb"))]
+    compatible = [record for record in records if record.architecture in (args.arch, "all")]
+    by_name: dict[str, Deb] = {}
+    by_provider: dict[str, Deb] = {}
+    for record in compatible:
+        current = by_name.get(record.package)
+        if current is None or record.path.stat().st_mtime_ns > current.path.stat().st_mtime_ns:
+            by_name[record.package] = record
+        for provided in record.provides:
+            by_provider.setdefault(provided, record)
+
+    queue = list(args.packages)
+    selected: dict[str, Deb] = {}
+    while queue:
+        requested = normalize_name(queue.pop(0))
+        if not requested or requested in selected:
+            continue
+        record = by_name.get(requested) or by_provider.get(requested)
+        if record is None:
+            print(f"No compatible .deb found for bootstrap dependency: {requested}", file=sys.stderr)
+            return 1
+        selected[record.package] = record
+        for group in record.dependencies.split(","):
+            if not group.strip():
+                continue
+            alternatives = [normalize_name(item) for item in group.split("|")]
+            dependency = next(
+                (item for item in alternatives if item in by_name or item in by_provider),
+                "",
+            )
+            if not dependency:
+                print(
+                    f"No compatible alternative for {record.package} dependency: {group.strip()}",
+                    file=sys.stderr,
+                )
+                return 1
+            queue.append(dependency)
+
+    for record in selected.values():
+        print(record.path)
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
